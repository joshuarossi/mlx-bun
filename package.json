{
  "name": "mlx-bun",
  "version": "0.0.7",
  "description": "Native MLX inference for Bun on Apple Silicon — local LLM server (OpenAI/Anthropic-compatible) and TypeScript library. No Python.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshuarossi/mlx-bun.git"
  },
  "homepage": "https://github.com/joshuarossi/mlx-bun#readme",
  "bugs": "https://github.com/joshuarossi/mlx-bun/issues",
  "keywords": [
    "mlx",
    "llm",
    "apple-silicon",
    "metal",
    "bun",
    "local-inference",
    "gemma",
    "openai-compatible",
    "anthropic"
  ],
  "bin": {
    "mlx-bun": "bin/mlx-bun.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "scripts": {
    "test": "bash scripts/test.sh",
    "link-cli": "chmod +x src/cli.ts && ln -sf $PWD/src/cli.ts $HOME/.bun/bin/mlx-bun && mlx-bun --version",
    "build:binary": "sh scripts/build-binary.sh",
    "release": "PUBLISH=1 sh scripts/release-binary.sh",
    "publish:npm": "bun publish"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@types/bun": "^1.3.14",
    "openai": "^6.42.0"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@earendil-works/pi-ai": "0.80.2",
    "@huggingface/jinja": "^0.5.9",
    "@huggingface/tokenizers": "^0.1.3",
    "fast-png": "^8.0.0",
    "typebox": "1.1.38"
  }
}
